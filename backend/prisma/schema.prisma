// Prisma schema for the Identity module (spec 004-authentication-identity)
// See specs/004-authentication-identity/data-model.md for the source of truth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OAuthProvider {
  google
  microsoft
}

enum SessionStatus {
  active
  revoked
}

enum TokenStatus {
  pending
  used
  expired
}

// UserStatus (spec 006-users): lifecycle of a User, independent of login credentials.
// See specs/006-users/data-model.md.
enum UserStatus {
  Pending
  Active
  Inactive
  Suspended
  Deleted
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  emailVerifiedAt  DateTime?
  passwordHash     String?
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String?
  mfaRecoveryCodes String[]  @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Profile + lifecycle fields (spec 006-users); owned by the users module at the
  // application layer even though the columns live on this identity-owned table
  // (see specs/006-users/research.md #1).
  firstName   String?
  lastName    String?
  avatarUrl   String?
  language    String     @default("es")
  timezone    String     @default("UTC")
  preferences Json       @default("{}")
  status      UserStatus @default(Active)
  deletedAt   DateTime?

  oauthAccounts          OAuthAccount[]
  sessions               Session[]
  devices                Device[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

model OAuthAccount {
  id                String        @id @default(uuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Device {
  id             String   @id @default(uuid())
  userId         String
  userAgent      String
  approxLocation String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@map("devices")
}

model Session {
  id                    String        @id @default(uuid())
  userId                String
  deviceId              String
  refreshTokenHash      String
  refreshTokenFamilyId  String
  status                SessionStatus @default(active)
  rememberMe            Boolean       @default(false)
  expiresAt             DateTime
  lastActivityAt        DateTime      @default(now())
  createdAt             DateTime      @default(now())
  revokedAt             DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenFamilyId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String      @id @default(uuid())
  userId    String
  tokenHash String
  status    TokenStatus @default(pending)
  expiresAt DateTime
  createdAt DateTime    @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String      @id @default(uuid())
  userId    String
  tokenHash String
  status    TokenStatus @default(pending)
  expiresAt DateTime
  createdAt DateTime    @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Organizations module (spec 005-organizations-multi-tenant)
// See specs/005-organizations-multi-tenant/data-model.md for the source of truth.
// Membership.userId and OrganizationInvitation.invitedByUserId reference User (above)
// by id only, without a Prisma relation, to keep the two modules decoupled at the
// schema level (Modular by Design, Constitution Principle II).

enum OrganizationPlan {
  Free
  Pro
  Enterprise
}

enum OrganizationStatus {
  active
  suspended
}

enum MembershipRole {
  Propietario
  Administrador
  Gerente
  Ventas
  Soporte
  Contabilidad
  Inventario
  RRHH
  Lector
}

enum MembershipStatus {
  active
}

enum InvitationStatus {
  pending
  accepted
  cancelled
  expired
}

enum AuditLogAction {
  OrganizationCreated
  OrganizationUpdated
  OrganizationSuspended
  OrganizationReactivated
  PlanChanged
  MemberInvited
  InvitationCancelled
  InvitationAccepted
  UserProfileUpdated
  UserStatusChanged
  RoleCreated
  RoleUpdated
  RoleDeleted
  RoleAssigned
  RoleRevoked
  PermissionGranted
  PermissionRevoked
  PermissionDenied
}

model Organization {
  id             String             @id @default(uuid())
  name           String
  timezone       String
  currency       String
  language       String
  logoUrl        String?
  customDomain   String?            @unique
  taxSettings    Json               @default("{}")
  enabledModules String[]           @default([])
  plan           OrganizationPlan   @default(Free)
  status         OrganizationStatus @default(active)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  memberships Membership[]
  invitations OrganizationInvitation[]
  auditLogs   AuditLog[]
  roles       Role[]

  @@map("organizations")
}

model Membership {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole
  status         MembershipStatus @default(active)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model OrganizationInvitation {
  id              String           @id @default(uuid())
  organizationId  String
  email           String
  role            MembershipRole
  tokenHash       String
  status          InvitationStatus @default(pending)
  invitedByUserId String
  createdAt       DateTime         @default(now())
  expiresAt       DateTime
  resolvedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("organization_invitations")
}

model AuditLog {
  id             String         @id @default(uuid())
  // Nullable (spec 006-users): account-level events like a User editing their own
  // profile aren't scoped to any Organization. Org-scoped events (spec 005 and
  // spec 006's status changes) always set this. See specs/006-users/research.md #7.
  organizationId String?
  actorUserId    String?
  action         AuditLogAction
  metadata       Json           @default("{}")
  occurredAt     DateTime       @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([occurredAt])
  @@map("audit_logs")
}

// Roles & Permissions module (spec 007-roles-permissions)
// See specs/007-roles-permissions/data-model.md for the source of truth.
// Additive over Membership.role (research.md #1) — Membership itself is not modified.
// RoleAssignment.membershipId and MembershipPermission.membershipId reference
// Membership (above) by id only, without a Prisma relation, following the same
// decoupling precedent as Membership.userId → User.

model Role {
  id                 String   @id @default(uuid())
  // null = default role, shared platform-wide (research.md #2); seeded idempotently
  // by DefaultRolesSeeder, never created directly through the API.
  organizationId     String?
  name               String
  isDefault          Boolean  @default(false)
  inheritsFromRoleId String?
  permissions        String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inheritsFromRole Role?            @relation("RoleInheritance", fields: [inheritsFromRoleId], references: [id])
  inheritedByRoles Role[]           @relation("RoleInheritance")
  assignments      RoleAssignment[]

  // NOTE: uniqueness of default-role names (organizationId = null) is enforced by
  // DefaultRolesSeeder being the only writer for that case, not by this DB constraint
  // — Postgres treats two NULLs in a composite unique index as distinct, so this index
  // only guarantees per-Organization uniqueness for custom roles (research.md #2).
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model RoleAssignment {
  id               String   @id @default(uuid())
  membershipId     String
  roleId           String
  assignedByUserId String
  createdAt        DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@map("role_assignments")
}

model MembershipPermission {
  id              String   @id @default(uuid())
  membershipId    String
  permission      String
  grantedByUserId String
  createdAt       DateTime @default(now())

  @@unique([membershipId, permission])
  @@index([membershipId])
  @@map("membership_permissions")
}
