// Prisma schema for the Identity module (spec 004-authentication-identity)
// See specs/004-authentication-identity/data-model.md for the source of truth.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OAuthProvider {
  google
  microsoft
}

enum SessionStatus {
  active
  revoked
}

enum TokenStatus {
  pending
  used
  expired
}

// UserStatus (spec 006-users): lifecycle of a User, independent of login credentials.
// See specs/006-users/data-model.md.
enum UserStatus {
  Pending
  Active
  Inactive
  Suspended
  Deleted
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  emailVerifiedAt  DateTime?
  passwordHash     String?
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String?
  mfaRecoveryCodes String[]  @default([])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Profile + lifecycle fields (spec 006-users); owned by the users module at the
  // application layer even though the columns live on this identity-owned table
  // (see specs/006-users/research.md #1).
  firstName   String?
  lastName    String?
  avatarUrl   String?
  language    String     @default("es")
  timezone    String     @default("UTC")
  preferences Json       @default("{}")
  status      UserStatus @default(Active)
  deletedAt   DateTime?

  oauthAccounts          OAuthAccount[]
  sessions               Session[]
  devices                Device[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

model OAuthAccount {
  id                String        @id @default(uuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Device {
  id             String   @id @default(uuid())
  userId         String
  userAgent      String
  approxLocation String?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@map("devices")
}

model Session {
  id                    String        @id @default(uuid())
  userId                String
  deviceId              String
  refreshTokenHash      String
  refreshTokenFamilyId  String
  status                SessionStatus @default(active)
  rememberMe            Boolean       @default(false)
  expiresAt             DateTime
  lastActivityAt        DateTime      @default(now())
  createdAt             DateTime      @default(now())
  revokedAt             DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenFamilyId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String      @id @default(uuid())
  userId    String
  tokenHash String
  status    TokenStatus @default(pending)
  expiresAt DateTime
  createdAt DateTime    @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String      @id @default(uuid())
  userId    String
  tokenHash String
  status    TokenStatus @default(pending)
  expiresAt DateTime
  createdAt DateTime    @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Organizations module (spec 005-organizations-multi-tenant)
// See specs/005-organizations-multi-tenant/data-model.md for the source of truth.
// Membership.userId and OrganizationInvitation.invitedByUserId reference User (above)
// by id only, without a Prisma relation, to keep the two modules decoupled at the
// schema level (Modular by Design, Constitution Principle II).

enum OrganizationPlan {
  Free
  Pro
  Enterprise
}

enum OrganizationStatus {
  active
  suspended
}

enum MembershipRole {
  Propietario
  Administrador
  Gerente
  Ventas
  Soporte
  Contabilidad
  Inventario
  RRHH
  Lector
}

enum MembershipStatus {
  active
}

enum InvitationStatus {
  pending
  accepted
  cancelled
  expired
}

enum AuditLogAction {
  OrganizationCreated
  OrganizationUpdated
  OrganizationSuspended
  OrganizationReactivated
  PlanChanged
  MemberInvited
  InvitationCancelled
  InvitationAccepted
  UserProfileUpdated
  UserStatusChanged
  RoleCreated
  RoleUpdated
  RoleDeleted
  RoleAssigned
  RoleRevoked
  PermissionGranted
  PermissionRevoked
  PermissionDenied
  CustomerCreated
  CustomerUpdated
  CustomerArchived
  CustomerRestored
  CustomerMerged
  CustomersExported
  CustomersImported
  ContactCreated
  ContactUpdated
  ContactCustomerChanged
  ContactPrimaryChanged
  ContactArchived
  ContactRestored
  ContactMerged
}

model Organization {
  id             String             @id @default(uuid())
  name           String
  timezone       String
  currency       String
  language       String
  logoUrl        String?
  customDomain   String?            @unique
  taxSettings    Json               @default("{}")
  enabledModules String[]           @default([])
  plan           OrganizationPlan   @default(Free)
  status         OrganizationStatus @default(active)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  memberships Membership[]
  invitations OrganizationInvitation[]
  auditLogs   AuditLog[]
  roles       Role[]
  customers   Customer[]
  contacts    Contact[]

  @@map("organizations")
}

model Membership {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole
  status         MembershipStatus @default(active)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model OrganizationInvitation {
  id              String           @id @default(uuid())
  organizationId  String
  email           String
  role            MembershipRole
  tokenHash       String
  status          InvitationStatus @default(pending)
  invitedByUserId String
  createdAt       DateTime         @default(now())
  expiresAt       DateTime
  resolvedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("organization_invitations")
}

model AuditLog {
  id             String         @id @default(uuid())
  // Nullable (spec 006-users): account-level events like a User editing their own
  // profile aren't scoped to any Organization. Org-scoped events (spec 005 and
  // spec 006's status changes) always set this. See specs/006-users/research.md #7.
  organizationId String?
  actorUserId    String?
  action         AuditLogAction
  metadata       Json           @default("{}")
  occurredAt     DateTime       @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([occurredAt])
  @@map("audit_logs")
}

// Roles & Permissions module (spec 007-roles-permissions)
// See specs/007-roles-permissions/data-model.md for the source of truth.
// Additive over Membership.role (research.md #1) — Membership itself is not modified.
// RoleAssignment.membershipId and MembershipPermission.membershipId reference
// Membership (above) by id only, without a Prisma relation, following the same
// decoupling precedent as Membership.userId → User.

model Role {
  id                 String   @id @default(uuid())
  // null = default role, shared platform-wide (research.md #2); seeded idempotently
  // by DefaultRolesSeeder, never created directly through the API.
  organizationId     String?
  name               String
  isDefault          Boolean  @default(false)
  inheritsFromRoleId String?
  permissions        String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inheritsFromRole Role?            @relation("RoleInheritance", fields: [inheritsFromRoleId], references: [id])
  inheritedByRoles Role[]           @relation("RoleInheritance")
  assignments      RoleAssignment[]

  // NOTE: uniqueness of default-role names (organizationId = null) is enforced by
  // DefaultRolesSeeder being the only writer for that case, not by this DB constraint
  // — Postgres treats two NULLs in a composite unique index as distinct, so this index
  // only guarantees per-Organization uniqueness for custom roles (research.md #2).
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model RoleAssignment {
  id               String   @id @default(uuid())
  membershipId     String
  roleId           String
  assignedByUserId String
  createdAt        DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@map("role_assignments")
}

model MembershipPermission {
  id              String   @id @default(uuid())
  membershipId    String
  permission      String
  grantedByUserId String
  createdAt       DateTime @default(now())

  @@unique([membershipId, permission])
  @@index([membershipId])
  @@map("membership_permissions")
}

// Customers module (spec 008-customers)
// See specs/008-customers/data-model.md for the source of truth.
// Customer.organizationId filters every query at the repository level (research.md
// #1). No physical delete ever — "eliminar" is always status = archived (RN-004).

enum CustomerType {
  person
  company
}

enum CustomerStatus {
  active
  inactive
  suspended
  archived
}

enum CustomerPriority {
  low
  medium
  high
}

model Customer {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  legalName      String?
  tradeName      String?
  type           CustomerType     @default(company)
  taxId          String?
  taxCondition   String?
  email          String?
  phone          String?
  website        String?
  country        String?
  state          String?
  city           String?
  address        String?
  ownerUserId    String?
  source         String?
  category       String?
  tags           String[]         @default([])
  priority       CustomerPriority @default(medium)
  customFields   Json             @default("{}")
  status         CustomerStatus   @default(active)
  // Non-null = this row was discarded in a merge; research.md #6. Never a new
  // CustomerStatus value — status keeps whatever it was before the merge.
  mergedIntoCustomerId String?
  version        Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mergedInto      Customer?         @relation("CustomerMerge", fields: [mergedIntoCustomerId], references: [id])
  mergedCustomers Customer[]        @relation("CustomerMerge")
  history         CustomerHistory[]
  contacts        Contact[]

  // NULLs don't count as duplicates in Postgres unique constraints (research.md #3):
  // multiple Customers without a taxId in the same Organization can coexist.
  @@unique([organizationId, taxId])
  @@index([organizationId, status])
  @@map("customers")
}

model CustomerHistory {
  id              String   @id @default(uuid())
  customerId      String
  changedByUserId String
  // { field: { before, after } } for the fields touched by that single edit
  // (research.md #4). Re-parented (customerId reassigned) to the survivor on a merge.
  changes         Json
  changedAt       DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_history")
}

// Contacts module (spec 009-contacts)
// See specs/009-contacts/data-model.md for the source of truth.
// Contact.customerId is a hard, non-nullable dependency on Customer (RN-001,
// research.md #1) — a Contact can never exist without exactly one Customer.

enum ContactStatus {
  active
  inactive
  archived
}

model Contact {
  id             String        @id @default(uuid())
  organizationId String
  customerId     String
  firstName      String
  lastName       String
  photoUrl       String?
  birthDate      DateTime?
  gender         String?
  jobTitle       String?
  department     String?
  area           String?
  decisionLevel  String?
  // Denormalized from Customer.name at creation time to avoid a JOIN on every
  // search-by-company (research.md #8) — not kept in strict sync if the Customer is
  // later renamed.
  company          String?
  primaryEmail     String?
  secondaryEmails  String[]         @default([])
  primaryPhone     String?
  secondaryPhones  String[]         @default([])
  whatsapp         String?
  linkedin         String?
  website          String?
  country          String?
  state            String?
  city             String?
  address          String?
  ownerUserId      String?
  status           ContactStatus    @default(active)
  tags             String[]         @default([])
  // Reuses Customer's priority enum (spec 008) — same business concept, not
  // duplicated as a separate ContactPriority type.
  priority         CustomerPriority @default(medium)
  // Defaults to false at most one per customerId enforced by a partial unique index
  // added by hand in the migration (research.md #4) — Prisma cannot express a
  // partial `WHERE is_primary = true` unique constraint in the schema itself.
  isPrimary        Boolean          @default(false)
  customFields     Json             @default("{}")
  // Non-null = this row was discarded in a merge (research.md #6); status keeps
  // whatever it was before the merge, same pattern as Customer.mergedIntoCustomerId.
  mergedIntoContactId String?
  version          Int              @default(1)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  mergedInto     Contact?        @relation("ContactMerge", fields: [mergedIntoContactId], references: [id])
  mergedContacts Contact[]       @relation("ContactMerge")
  history        ContactHistory[]

  @@index([organizationId, status])
  @@index([customerId])
  @@map("contacts")
}

model ContactHistory {
  id              String   @id @default(uuid())
  contactId       String
  changedByUserId String
  changes         Json
  changedAt       DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_history")
}
